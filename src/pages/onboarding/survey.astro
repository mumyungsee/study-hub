---
import Base from '../../layouts/Base.astro';
---

<Base title="사전 설문조사 — AI 스터디 허브">
  <h1>사전 설문조사</h1>

  <div class="intro-box">
    <p>미리 알면, 그만큼 더 잘 챙겨드릴 수 있어요.</p>
    <p>"잘 모른다"고 답하셔도 괜찮습니다. <strong>솔직하게 답해주세요.</strong></p>
  </div>

  <div class="form-wrap">
    <iframe
      src="https://docs.google.com/forms/d/e/1FAIpQLSfLPAXalfcZus1Hs_4F2OEHB5zJEDIb0uXRcUHni-NbmdvdnA/viewform?embedded=true"
      width="100%"
      height="2200"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
    >
      로딩 중...
    </iframe>
  </div>
</Base>

<style>
  .intro-box {
    margin: 1rem 0 1.5rem;
    padding: 1rem 1.2rem;
    background: #fff7ed;
    border-left: 4px solid var(--accent);
    border-radius: 4px;
  }
  .intro-box p {
    margin: 0.3rem 0;
    line-height: 1.65;
    font-size: 0.95rem;
  }
  .intro-box p:first-child { margin-top: 0; }
  .intro-box p:last-child { margin-bottom: 0; }
  .form-wrap {
    margin-top: 1.5rem;
    border-radius: 8px;
    overflow: hidden;
  }
  iframe {
    display: block;
  }
</style>
