---
import Base from '../../layouts/Base.astro';
---

<Base title="사전 설문조사 — 나만의 라이프 위키">
  <h1>사전 설문조사</h1>
  <p>스터디를 시작하기 전에 간단한 설문에 응답해 주세요. 약 3~5분 정도 걸립니다.</p>

  <div class="form-wrap">
    <iframe
      src="https://docs.google.com/forms/d/e/1FAIpQLSfLPAXalfcZus1Hs_4F2OEHB5zJEDIb0uXRcUHni-NbmdvdnA/viewform?embedded=true"
      width="100%"
      height="900"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
    >
      로딩 중...
    </iframe>
  </div>
</Base>

<style>
  .form-wrap {
    margin-top: 1.5rem;
    border-radius: 8px;
    overflow: hidden;
  }
  iframe {
    display: block;
  }
</style>
