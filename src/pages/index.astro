---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => post.data.status === '공개' || post.data.status === '책_챕터_후보')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
---

<Base title="나만의 라이프 위키">
  <section class="hero">
    <p class="eyebrow">Life Wiki</p>
    <h1>회고에서 글과 도구가 자라는 개인 작업 공간</h1>
    <p>
      매일의 기록을 안전하게 쌓고, 공개할 만한 발견은 글과 튜토리얼로 다듬어 발행합니다.
      지금은 글과 라이프 위키 튜토리얼을 중심으로 운영합니다.
    </p>
  </section>

  <section class="section-grid" aria-label="주요 섹션">
    <a class="section-link" href="/blog/">
      <span class="section-kicker">Blog</span>
      <strong>글</strong>
      <span>회고에서 길어 올린 기록과 발견</span>
    </a>
    <a class="section-link" href="/tutorial/">
      <span class="section-kicker">Tutorial</span>
      <strong>튜토리얼</strong>
      <span>AI 도구로 라이프 위키를 만드는 과정</span>
    </a>
    <a class="section-link" href="/gallery/">
      <span class="section-kicker">Gallery</span>
      <strong>수강생 사례</strong>
      <span>라이프 위키를 만든 수강생들의 실제 경험</span>
    </a>
  </section>

  <section class="recent">
    <div class="section-heading">
      <h2>최근 글</h2>
      <a href="/blog/">전체 보기</a>
    </div>
    {posts.map((post) => (
      <article class="post-row">
        <p>{fmt(post.data.date)}</p>
        <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
      </article>
    ))}
  </section>

  <style>
    .hero {
      margin-bottom: 2.5rem;
    }
    .eyebrow {
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0;
      margin: 0 0 0.4rem;
      text-transform: uppercase;
    }
    .hero h1 {
      font-size: 2rem;
      margin-bottom: 0.85rem;
    }
    .hero p:last-child {
      color: var(--muted);
    }
    .section-grid {
      display: grid;
      gap: 1rem;
      margin: 2rem 0 3rem;
    }
    .section-link {
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--fg);
      display: block;
      padding: 1rem;
      text-decoration: none;
    }
    .section-link:hover {
      border-color: var(--accent);
    }
    .section-link strong {
      display: block;
      font-size: 1.1rem;
      margin: 0.1rem 0 0.25rem;
    }
    .section-link span:last-child {
      color: var(--muted);
      display: block;
      font-size: 0.95rem;
    }
    .section-link-muted {
      background: #f3f0e8;
    }
    .section-kicker {
      color: var(--muted);
      display: block;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .section-heading {
      align-items: baseline;
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.75rem;
    }
    .section-heading h2 {
      margin: 0;
    }
    .section-heading a {
      color: var(--muted);
      font-size: 0.9rem;
      text-decoration: none;
    }
    .post-row {
      border-bottom: 1px solid var(--line);
      padding: 1rem 0;
    }
    .post-row p {
      color: var(--muted);
      font-size: 0.85rem;
      margin: 0;
    }
    .post-row h3 {
      font-size: 1.05rem;
      margin: 0.2rem 0 0;
    }
    .post-row a {
      color: var(--fg);
      text-decoration: none;
    }
    .post-row a:hover {
      color: var(--accent);
    }
  </style>
</Base>
