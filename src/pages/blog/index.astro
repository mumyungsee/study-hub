---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => post.data.status === '공개' || post.data.status === '책_챕터_후보')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="기록과 발견">
  <section class="intro">
    <p class="eyebrow">Blog</p>
    <h1>기록과 발견</h1>
    <p>매일의 회고에서 길어 올린 글들을 모아둡니다.<br />자립, 강의, 건강, 일상에서 발견한 작은 패턴들.</p>
  </section>

  <p class="hint">왼쪽 목차에서 글을 골라 읽어보세요.</p>

  <style>
    .eyebrow {
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
      margin: 0 0 0.4rem;
    }
    .intro { margin-bottom: 2rem; }
    .intro h1 { font-size: 2rem; margin: 0.25rem 0 0.75rem; }
    .intro p { color: var(--muted); margin: 0; }
    .hint { color: var(--muted); font-style: italic; }
  </style>
</Base>
