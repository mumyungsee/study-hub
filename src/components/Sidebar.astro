---
import { getCollection } from 'astro:content';

const pathname = Astro.url.pathname;

const tutorials = (await getCollection('tutorial'))
  .filter((t) => t.data.status === '공개')
  .sort((a, b) => a.data.chapter - b.data.chapter || a.data.order - b.data.order);

const required = tutorials.filter((t) => t.data.track === '필수');
const advanced = tutorials.filter((t) => t.data.track === '심화');
const appendix = tutorials.filter((t) => t.data.track === '부록');

// 트랙별 펼침 여부 (현재 보고 있는 강의가 속한 트랙만 열기)
const isInRequired = required.some(t => pathname === `/tutorial/${t.slug}/`);
const isInAdvanced = advanced.some(t => pathname === `/tutorial/${t.slug}/`);
const isInAppendix = appendix.some(t => pathname === `/tutorial/${t.slug}/`);
const isInTutorialIndex = pathname === '/tutorial/';
const noneOpen = !isInRequired && !isInAdvanced && !isInAppendix;
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-inner">
    <nav aria-label="학습 메뉴">

      {/* 온보딩 — 항상 펼침 */}
      <div class="sidebar-group">
        <div class="sidebar-group-title">온보딩</div>
        <div class="sidebar-group-items">
          <a href="/onboarding/glossary/" class:list={['sidebar-link', { active: pathname === '/onboarding/glossary/' }]}>
            용어 정리
          </a>
          <a href="/onboarding/intro/" class:list={['sidebar-link', { active: pathname === '/onboarding/intro/' }]}>
            스터디 소개
          </a>
          <a href="/onboarding/how-to-use/" class:list={['sidebar-link', { active: pathname === '/onboarding/how-to-use/' }]}>
            이 스터디 사용법
          </a>
          <a href="/onboarding/survey/" class:list={['sidebar-link', { active: pathname === '/onboarding/survey/' }]}>
            사전 설문조사
          </a>
          <a href="/onboarding/roles/" class:list={['sidebar-link', { active: pathname === '/onboarding/roles/' }]}>
            역할 배정
          </a>
        </div>
      </div>

      {/* 환경 세팅 — 항상 펼침 */}
      <div class="sidebar-group">
        <div class="sidebar-group-title">환경 세팅</div>
        <div class="sidebar-group-items">
          <a href="/setup/antigravity/" class:list={['sidebar-link', { active: pathname === '/setup/antigravity/' }]}>
            Antigravity 설치
          </a>
          <a href="/setup/claude-code/" class:list={['sidebar-link', { active: pathname === '/setup/claude-code/' }]}>
            Claude Code 설치
          </a>
        </div>
      </div>

      {/* 튜토리얼 — 트랙별 접고 펼치기 */}
      {(required.length > 0 || advanced.length > 0 || appendix.length > 0) && (
        <div class="sidebar-group">
          <div class="sidebar-group-title">튜토리얼</div>
          <div class="sidebar-group-items">

            {required.length > 0 && (
              <details class="sidebar-subgroup" open={isInRequired || isInTutorialIndex || noneOpen}>
                <summary class="sidebar-subgroup-title">필수 강의</summary>
                <div class="sidebar-subgroup-items">
                  {required.map((t) => (
                    <a
                      href={`/tutorial/${t.slug}/`}
                      class:list={['sidebar-link', { active: pathname === `/tutorial/${t.slug}/` }]}
                    >
                      {t.data.title}
                    </a>
                  ))}
                </div>
              </details>
            )}

            {advanced.length > 0 && (
              <details class="sidebar-subgroup" open={isInAdvanced}>
                <summary class="sidebar-subgroup-title">심화 강의</summary>
                <div class="sidebar-subgroup-items">
                  {advanced.map((t) => (
                    <a
                      href={`/tutorial/${t.slug}/`}
                      class:list={['sidebar-link', { active: pathname === `/tutorial/${t.slug}/` }]}
                    >
                      {t.data.title}
                    </a>
                  ))}
                </div>
              </details>
            )}

            {appendix.length > 0 && (
              <details class="sidebar-subgroup" open={isInAppendix}>
                <summary class="sidebar-subgroup-title">부록</summary>
                <div class="sidebar-subgroup-items">
                  {appendix.map((t) => (
                    <a
                      href={`/tutorial/${t.slug}/`}
                      class:list={['sidebar-link', { active: pathname === `/tutorial/${t.slug}/` }]}
                    >
                      {t.data.title}
                    </a>
                  ))}
                </div>
              </details>
            )}

          </div>
        </div>
      )}

    </nav>
  </div>
</aside>

<style>
  .sidebar {
    width: var(--sidebar-width, 260px);
    height: calc(100vh - var(--header-height, 52px));
    position: sticky;
    top: var(--header-height, 52px);
    overflow-y: auto;
    border-right: 1px solid var(--line);
    flex-shrink: 0;
  }

  .sidebar-inner {
    padding: 1rem 0.5rem 2rem;
    min-width: var(--sidebar-width, 260px);
  }

  /* === 최상위 그룹 (온보딩 / 환경 세팅 / 튜토리얼) === */
  .sidebar-group {
    margin-bottom: 1.1rem;
  }
  .sidebar-group-title {
    padding: 0.35rem 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.1rem;
  }
  .sidebar-group-items {
    /* 들여쓰기 없음 — 위키 스타일 */
  }

  /* === 서브 그룹 (필수/심화/부록) — 접고 펼치기 === */
  .sidebar-subgroup {
    margin-bottom: 0.2rem;
  }
  .sidebar-subgroup-title {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--fg);
    cursor: pointer;
    border-radius: 5px;
    list-style: none;
    user-select: none;
  }
  .sidebar-subgroup-title:hover { background: var(--line); }

  /* 화살표 */
  .sidebar-subgroup-title::before {
    content: '›';
    font-size: 0.9rem;
    line-height: 1;
    transition: transform 0.15s;
    color: var(--muted);
    width: 0.7rem;
  }
  details[open] > .sidebar-subgroup-title::before {
    transform: rotate(90deg);
  }
  .sidebar-subgroup-title::-webkit-details-marker { display: none; }

  .sidebar-subgroup-items {
    padding: 0.15rem 0 0.3rem 0.95rem;
  }

  /* === 링크 공통 === */
  .sidebar-link {
    display: block;
    padding: 0.3rem 0.5rem 0.3rem 0.75rem;
    font-size: 0.87rem;
    color: var(--fg);
    text-decoration: none;
    border-radius: 5px;
    line-height: 1.45;
  }
  .sidebar-link:hover { background: var(--line); }
  .sidebar-link.active {
    background: #ede8df;
    color: var(--accent);
    font-weight: 600;
  }

  /* 모바일 */
  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      top: var(--header-height, 52px);
      left: 0;
      width: var(--sidebar-width, 260px) !important;
      height: calc(100vh - var(--header-height, 52px));
      background: var(--bg);
      z-index: 50;
      transform: translateX(-100%);
      transition: transform 0.22s ease;
      border-right: 1px solid var(--line);
      box-shadow: 2px 0 12px rgba(0,0,0,0.1);
      overflow-y: auto;
    }
    .sidebar.mobile-open {
      transform: translateX(0);
    }
  }
</style>
