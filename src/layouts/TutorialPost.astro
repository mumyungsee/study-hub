---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props extends CollectionEntry<'tutorial'>['data'] {
  prev?: CollectionEntry<'tutorial'> | null;
  next?: CollectionEntry<'tutorial'> | null;
}

const { title, description, chapter, prev, next } = Astro.props;
---

<Base title={title} description={description ?? title}>
  <article>
    <header class="tutorial-header">
      <p class="chapter-label">{chapter}ВъЦ</p>
      <h1>{title}</h1>
      {description && <p>{description}</p>}
    </header>
    <div class="tutorial-body">
      <slot />
    </div>
    <footer class="tutorial-footer">
      <nav class="tutorial-nav">
        <div class="nav-prev">
          {prev && (
            <a href={`/tutorial/${prev.slug}/`}>
              <span class="nav-label">Рєљ ВЮ┤Ваё</span>
              <span class="nav-title">{prev.data.title}</span>
            </a>
          )}
        </div>
        <div class="nav-center">
          <a href="/tutorial/">вфЕвАЮ</a>
        </div>
        <div class="nav-next">
          {next && (
            <a href={`/tutorial/${next.slug}/`}>
              <span class="nav-label">вІцВЮї Рєњ</span>
              <span class="nav-title">{next.data.title}</span>
            </a>
          )}
        </div>
      </nav>
    </footer>
  </article>
  <style>
    .tutorial-header {
      margin-bottom: 2rem;
    }
    .chapter-label {
      color: var(--accent);
      font-size: 0.85rem;
      font-weight: 700;
      margin: 0 0 0.4rem;
    }
    .tutorial-header > p:last-child {
      color: var(--muted);
    }
    .tutorial-body :global(p) {
      line-height: 1.85;
    }
    .tutorial-body :global(ol),
    .tutorial-body :global(ul) {
      padding-left: 1.4rem;
    }
    .tutorial-footer {
      border-top: 1px solid var(--line);
      margin-top: 3rem;
      padding-top: 1.5rem;
    }
    .tutorial-nav {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 1rem;
      align-items: center;
    }
    .nav-prev { text-align: left; }
    .nav-next { text-align: right; }
    .nav-center { text-align: center; font-size: 0.85rem; }
    .tutorial-nav a {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .tutorial-nav a:hover { text-decoration: underline; }
    .nav-label {
      font-size: 0.75rem;
      color: var(--muted);
    }
    .nav-title {
      font-size: 0.9rem;
      font-weight: 500;
    }

    /* ВйћвЊю вИћвАЮ в│хВѓг в▓ёьі╝ */
    .tutorial-body :global(pre) {
      position: relative;
    }
    .tutorial-body :global(.copy-btn) {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      padding: 0.2rem 0.6rem;
      font-size: 0.72rem;
      background: rgba(0,0,0,0.08);
      border: 1px solid rgba(0,0,0,0.12);
      border-radius: 4px;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.15s;
      color: inherit;
      font-family: inherit;
    }
    .tutorial-body :global(pre:hover .copy-btn) {
      opacity: 1;
    }
    .tutorial-body :global(.copy-btn.copied) {
      background: rgba(0,160,80,0.12);
      border-color: rgba(0,160,80,0.3);
      color: #0a7a40;
      opacity: 1;
    }

    /* ВџЕВќ┤ ьѕ┤ьїЂ */
    .tutorial-body :global(.glossary-term) {
      border-bottom: 1px dashed var(--muted);
      cursor: help;
      position: relative;
    }
    .tutorial-body :global(.glossary-term::before) {
      content: '';
      position: absolute;
      bottom: calc(100% + 2px);
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: #1e1e1e;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 101;
    }
    .tutorial-body :global(.glossary-term::after) {
      content: attr(data-tooltip);
      position: absolute;
      bottom: calc(100% + 12px);
      left: 50%;
      transform: translateX(-50%);
      background: #1e1e1e;
      color: #f0f0f0;
      font-size: 0.72rem;
      line-height: 1.5;
      padding: 0.35rem 0.6rem;
      border-radius: 5px;
      width: max-content;
      max-width: min(220px, 80vw);
      white-space: normal;
      text-align: center;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 100;
    }
    .tutorial-body :global(.glossary-term:hover::before),
    .tutorial-body :global(.glossary-term:hover::after) {
      opacity: 1;
    }
  </style>

  <script>
    // ВйћвЊю вИћвАЮ в│хВѓг в▓ёьі╝
    document.querySelectorAll('.tutorial-body pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'в│хВѓг';
      pre.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.innerText : pre.innerText;
        await navigator.clipboard.writeText(text);
        btn.textContent = 'в│хВѓгвље';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'в│хВѓг';
          btn.classList.remove('copied');
        }, 1500);
      });
    });

    // URL ВъљвЈЎ ьЋўВЮ┤ьЇ╝вДЂьЂг
    const urlRegex = /https?:\/\/[^\s<>"'№╝Ѕ)]+/g;

    // 1. ВЮ╝в░ў ьЁЇВіцьіИ вЁИвЊю ВЋѕВЮў URL (p, li ВДЂВаЉ ВъљВІЮ ьЁЇВіцьіИ)
    document.querySelectorAll('.tutorial-body p, .tutorial-body li').forEach((el) => {
      el.childNodes.forEach((node) => {
        if (node.nodeType !== Node.TEXT_NODE) return;
        const text = node.textContent;
        if (!urlRegex.test(text)) return;
        urlRegex.lastIndex = 0;
        const span = document.createElement('span');
        span.innerHTML = text.replace(urlRegex, (url) =>
          `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`
        );
        node.replaceWith(span);
      });
    });

    // 2. ВЮИвЮ╝ВЮИ ВйћвЊю(`url`) ВЋѕВЮў URL Рђћ pre вИћвАЮ ВаюВЎИ
    document.querySelectorAll('.tutorial-body :not(pre) > code').forEach((code) => {
      const text = code.textContent ?? '';
      if (!urlRegex.test(text)) return;
      urlRegex.lastIndex = 0;
      const a = document.createElement('a');
      a.href = text.trim();
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.appendChild(code.cloneNode(true));
      code.replaceWith(a);
    });

    // ВџЕВќ┤ ьѕ┤ьїЂ
    const glossaryTerms = [
      { regex: /В╗цв░І/g, tip: 'ьїїВЮ╝ в│ђЖ▓й ВѓгьЋГВЮё ЖИ░вАЮьЋўвіћ Ж▓Ѓ. Ж▓їВъёВЮў ВёИВЮ┤вИїьЈгВЮИьіИ Ж░ЎВЮђ Ж░ювЁљ' },
      { regex: /ьЉИВІю/g, tip: 'вѓ┤ В╗┤ьЊеьё░ВЮў В╗цв░ІВЮё GitHubВЌљ Вўгвдгвіћ Ж▓Ѓ' },
      { regex: /ьЈгьЂг/g, tip: 'вѓеВЮў ВађВъЦВєївЦ╝ вѓ┤ Ж│ёВаЋВю╝вАю в│хВѓгьЋ┤ Вўцвіћ Ж▓Ѓ' },
      { regex: /ьЂ┤вАа/g, tip: 'ВађВъЦВєївЦ╝ вѓ┤ В╗┤ьЊеьё░ВЌљ вѓ┤вацв░Џвіћ Ж▓Ѓ' },
      { regex: /ВађВъЦВєї/g, tip: 'ВйћвЊюВЎђ ьїїВЮ╝ВЮё вІ┤ВЋёвЉљвіћ Ж│хЖ░ё. GitHubВЮў ьћёвАюВаЮьіИ ьЈ┤вЇћ' },
      { regex: /в░░ьЈг/g, tip: 'вДївЊа ВѓгВЮ┤ьіИвЦ╝ ВЮИьё░вёиВЌљ Вўгвац вѕёЖхгвѓў в│╝ Вѕў ВъѕЖ▓ї ьЋўвіћ Ж▓Ѓ' },
      { regex: /в╣ївЊю/g, tip: 'ВєїВіц ВйћвЊювЦ╝ ВІцВаю ВѓгВЮ┤ьіИ ьїїВЮ╝вАю в│ђьЎўьЋўвіћ Ж│╝ВаЋ' },
      { regex: /ьё░в»Ивёљ/g, tip: 'вфЁва╣Вќ┤вЦ╝ ВъЁваЦьЋ┤ В╗┤ьЊеьё░вЦ╝ ВА░ВъЉьЋўвіћ Ж▓ђВЮђ ьЎћвЕ┤' },
      { regex: /ВўцьћѕВєїВіц/g, tip: 'ВйћвЊювЦ╝ вѕёЖхгвѓў в│╝ Вѕў ВъѕЖ▓ї Ж│хЖ░юьЋю ьћёвАюВаЮьіИ. Ж░ђВаИвІц ВЊ░Ж▒░вѓў ВѕўВаЋьЋа Вѕў ВъѕВЮї' },
      { regex: /ваѕьЈг(?!\s*ВДђ)/g, tip: 'ВађВъЦВєїВЮў ВцёВъёвДљ (repository Рєњ repo). GitHubВЮў ьћёвАюВаЮьіИ Ж│хЖ░ё' },
      { regex: /вДѕьЂгвІцВџ┤/g, tip: '#Вю╝вАю ВаювфЕ, **вАю ЖххЖ▓ї вЊ▒ ЖИ░ьўИвАю ВёюВІЮВЮё ьЉюьўёьЋўвіћ ьЁЇВіцьіИ ьўЋВІЮ' },
      { regex: /вИївъюВ╣ў/g, tip: 'ВйћвЊюВЮў вЈЁвдйВаЂВЮИ ВъЉВЌЁ ьЮљвдё. mainВЮ┤ ЖИ░в│И вИївъюВ╣ў' },
      { regex: /вЮ╝ВЮ┤ВёаВіц/g, tip: 'ВўцьћѕВєїВіцвЦ╝ Ж░ђВаИвІц ВЊИ вЋї ВДђВ╝юВЋ╝ ьЋўвіћ ВА░Ж▒┤Ж│╝ ЖиюВ╣Ў' },
      { regex: /вЮ╝ВЮ┤Вё╝Віц/g, tip: 'ВўцьћѕВєїВіцвЦ╝ Ж░ђВаИвІц ВЊИ вЋї ВДђВ╝юВЋ╝ ьЋўвіћ ВА░Ж▒┤Ж│╝ ЖиюВ╣Ў' },
      { regex: /вАюВ╗г/g, tip: 'вѓ┤ В╗┤ьЊеьё░ ВЋѕВЌљВёювДї вЈЎВъЉ. ВЮИьё░вёиВЌљвіћ ВЋёВДЂ Ж│хЖ░ю ВЋѕ вљю ВЃЂьЃю' },
      { regex: /ВъљВЌ░Вќ┤/g, tip: 'ВйћвЊювѓў вфЁва╣Вќ┤Ж░ђ ВЋёвІї, ьЈЅВєї ВЊ░віћ ВЮ╝ВЃЂ ВќИВќ┤' },
      { regex: /\bFork\b/g, tip: 'вѓеВЮў ВађВъЦВєївЦ╝ вѓ┤ Ж│ёВаЋВю╝вАю в│хВѓгьЋ┤ Вўцвіћ Ж▓Ѓ' },
      { regex: /\bClone\b/g, tip: 'ВађВъЦВєївЦ╝ вѓ┤ В╗┤ьЊеьё░ВЌљ вѓ┤вацв░Џвіћ Ж▓Ѓ' },
      { regex: /\bpush\b/g, tip: 'вѓ┤ В╗┤ьЊеьё░ВЮў В╗цв░ІВЮё GitHubВЌљ Вўгвдгвіћ Ж▓Ѓ' },
      { regex: /\bcommit\b/g, tip: 'ьїїВЮ╝ в│ђЖ▓й ВѓгьЋГВЮё ЖИ░вАЮьЋўвіћ Ж▓Ѓ. Ж▓їВъёВЮў ВёИВЮ┤вИїьЈгВЮИьіИ Ж░ЎВЮђ Ж░ювЁљ' },
      { regex: /\bMarkdown\b/g, tip: '#Вю╝вАю ВаювфЕ, **вАю ЖххЖ▓ї вЊ▒ ЖИ░ьўИвАю ВёюВІЮВЮё ьЉюьўёьЋўвіћ ьЁЇВіцьіИ ьўЋВІЮ' },
      { regex: /\bMIT\b/g, tip: 'Ж░ђВъЦ ВъљВюавАюВџ┤ ВўцьћѕВєїВіц вЮ╝ВЮ┤ВёаВіц. ВѕўВаЋ┬иВъгв░░ьЈг┬иВЃЂВЌЁ ВЮ┤ВџЕ вфевЉљ ьЌѕВџЕ' },
      { regex: /\bPrivate\b/g, tip: 'вѓўвДї в│╝ Вѕў Въѕвіћ ВађВъЦВєї ВёцВаЋ' },
      { regex: /\bPublic\b/g, tip: 'вѕёЖхгвѓў в│╝ Вѕў Въѕвіћ ВађВъЦВєї ВёцВаЋ' },
    ];

    function applyGlossary(container) {
      const walker = document.createTreeWalker(
        container,
        NodeFilter.SHOW_TEXT,
        {
          acceptNode(node) {
            const skip = node.parentElement?.closest('pre, code, a, .glossary-term, h1, h2, h3');
            return skip ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT;
          }
        }
      );

      const textNodes = [];
      let n;
      while ((n = walker.nextNode())) textNodes.push(n);

      for (const textNode of textNodes) {
        const text = textNode.textContent ?? '';

        // вфевЊа ВџЕВќ┤ВЮў вДцВ╣Г ВюёВ╣ў ВѕўВДЉ
        const matches = [];
        for (const { regex, tip } of glossaryTerms) {
          regex.lastIndex = 0;
          let m;
          while ((m = regex.exec(text)) !== null) {
            matches.push({ start: m.index, end: m.index + m[0].length, term: m[0], tip });
          }
        }
        if (matches.length === 0) continue;

        // ВюёВ╣ўВѕю ВаЋваг, Ж▓╣В╣ўвіћ Ж▓Ѓ ВаюЖ▒░
        matches.sort((a, b) => a.start - b.start);
        const kept = [];
        let cursor = 0;
        for (const m of matches) {
          if (m.start >= cursor) { kept.push(m); cursor = m.end; }
        }

        // ьЁЇВіцьіИ вЁИвЊювЦ╝ вХёьЋ┤ьЋ┤Вёю spanВю╝вАю ЖхљВ▓┤
        const frag = document.createDocumentFragment();
        let pos = 0;
        for (const m of kept) {
          if (m.start > pos) frag.appendChild(document.createTextNode(text.slice(pos, m.start)));
          const span = document.createElement('span');
          span.className = 'glossary-term';
          span.dataset.tooltip = m.tip;
          span.textContent = m.term;
          frag.appendChild(span);
          pos = m.end;
        }
        if (pos < text.length) frag.appendChild(document.createTextNode(text.slice(pos)));
        textNode.replaceWith(frag);
      }
    }

    const tutorialBody = document.querySelector('.tutorial-body');
    if (tutorialBody) applyGlossary(tutorialBody);
  </script>
</Base>
