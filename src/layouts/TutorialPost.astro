---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'tutorial'>['data'];

const { title, description, chapter } = Astro.props;
---

<Base title={title} description={description ?? title}>
  <article>
    <header class="tutorial-header">
      <p class="chapter-label">{chapter}장</p>
      <h1>{title}</h1>
      {description && <p>{description}</p>}
    </header>
    <div class="tutorial-body">
      <slot />
    </div>
    <footer class="tutorial-footer">
      <a href="/tutorial/">← 튜토리얼 목록으로</a>
    </footer>
  </article>
  <style>
    .tutorial-header {
      margin-bottom: 2rem;
    }
    .chapter-label {
      color: var(--accent);
      font-size: 0.85rem;
      font-weight: 700;
      margin: 0 0 0.4rem;
    }
    .tutorial-header > p:last-child {
      color: var(--muted);
    }
    .tutorial-body :global(p) {
      line-height: 1.85;
    }
    .tutorial-body :global(ol),
    .tutorial-body :global(ul) {
      padding-left: 1.4rem;
    }
    .tutorial-footer {
      border-top: 1px solid var(--line);
      margin-top: 3rem;
      padding-top: 1.5rem;
    }

    /* 코드 블록 복사 버튼 */
    .tutorial-body :global(pre) {
      position: relative;
    }
    .tutorial-body :global(.copy-btn) {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      padding: 0.2rem 0.6rem;
      font-size: 0.72rem;
      background: rgba(0,0,0,0.08);
      border: 1px solid rgba(0,0,0,0.12);
      border-radius: 4px;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.15s;
      color: inherit;
      font-family: inherit;
    }
    .tutorial-body :global(pre:hover .copy-btn) {
      opacity: 1;
    }
    .tutorial-body :global(.copy-btn.copied) {
      background: rgba(0,160,80,0.12);
      border-color: rgba(0,160,80,0.3);
      color: #0a7a40;
      opacity: 1;
    }
  </style>

  <script>
    // 코드 블록 복사 버튼
    document.querySelectorAll('.tutorial-body pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = '복사';
      pre.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.innerText : pre.innerText;
        await navigator.clipboard.writeText(text);
        btn.textContent = '복사됨';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = '복사';
          btn.classList.remove('copied');
        }, 1500);
      });
    });

    // URL 자동 하이퍼링크 (코드 블록 제외, 일반 텍스트 안에서만)
    const urlRegex = /https?:\/\/[^\s<>"'）)]+/g;
    document.querySelectorAll('.tutorial-body p, .tutorial-body li').forEach((el) => {
      el.childNodes.forEach((node) => {
        if (node.nodeType !== Node.TEXT_NODE) return;
        const text = node.textContent;
        if (!urlRegex.test(text)) return;
        urlRegex.lastIndex = 0;
        const span = document.createElement('span');
        span.innerHTML = text.replace(urlRegex, (url) =>
          `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`
        );
        node.replaceWith(span);
      });
    });
  </script>
</Base>
