---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props extends CollectionEntry<'tutorial'>['data'] {
  prev?: CollectionEntry<'tutorial'> | null;
  next?: CollectionEntry<'tutorial'> | null;
}

const { title, description, chapter, prev, next } = Astro.props;
---

<Base title={title} description={description ?? title}>
  <article>
    <header class="tutorial-header">
      <p class="chapter-label">{chapter}장</p>
      <h1>{title}</h1>
      {description && <p>{description}</p>}
    </header>
    <div class="tutorial-body">
      <slot />
    </div>
    <footer class="tutorial-footer">
      <nav class="tutorial-nav">
        <div class="nav-prev">
          {prev && (
            <a href={`/tutorial/${prev.slug}/`}>
              <span class="nav-label">← 이전</span>
              <span class="nav-title">{prev.data.title}</span>
            </a>
          )}
        </div>
        <div class="nav-center">
          <a href="/tutorial/">목록</a>
        </div>
        <div class="nav-next">
          {next && (
            <a href={`/tutorial/${next.slug}/`}>
              <span class="nav-label">다음 →</span>
              <span class="nav-title">{next.data.title}</span>
            </a>
          )}
        </div>
      </nav>
    </footer>
  </article>
  <style>
    .tutorial-header {
      margin-bottom: 2rem;
    }
    .chapter-label {
      color: var(--accent);
      font-size: 0.85rem;
      font-weight: 700;
      margin: 0 0 0.4rem;
    }
    .tutorial-header > p:last-child {
      color: var(--muted);
    }
    .tutorial-body :global(p) {
      line-height: 1.85;
    }
    .tutorial-body :global(ol),
    .tutorial-body :global(ul) {
      padding-left: 1.4rem;
    }
    .tutorial-footer {
      border-top: 1px solid var(--line);
      margin-top: 3rem;
      padding-top: 1.5rem;
    }
    .tutorial-nav {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 1rem;
      align-items: center;
    }
    .nav-prev { text-align: left; }
    .nav-next { text-align: right; }
    .nav-center { text-align: center; font-size: 0.85rem; }
    .tutorial-nav a {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .tutorial-nav a:hover { text-decoration: underline; }
    .nav-label {
      font-size: 0.75rem;
      color: var(--muted);
    }
    .nav-title {
      font-size: 0.9rem;
      font-weight: 500;
    }

    /* 코드 블록 복사 버튼 */
    .tutorial-body :global(pre) {
      position: relative;
    }
    .tutorial-body :global(.copy-btn) {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      padding: 0.2rem 0.6rem;
      font-size: 0.72rem;
      background: rgba(0,0,0,0.08);
      border: 1px solid rgba(0,0,0,0.12);
      border-radius: 4px;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.15s;
      color: inherit;
      font-family: inherit;
    }
    .tutorial-body :global(pre:hover .copy-btn) {
      opacity: 1;
    }
    .tutorial-body :global(.copy-btn.copied) {
      background: rgba(0,160,80,0.12);
      border-color: rgba(0,160,80,0.3);
      color: #0a7a40;
      opacity: 1;
    }

    /* 용어 툴팁 */
    .tutorial-body :global(.glossary-term) {
      border-bottom: 1px dashed var(--muted);
      cursor: help;
      position: relative;
    }
    .tutorial-body :global(.glossary-term::before) {
      content: '';
      position: absolute;
      bottom: calc(100% + 2px);
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: #1e1e1e;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 101;
    }
    .tutorial-body :global(.glossary-term::after) {
      content: attr(data-tooltip);
      position: absolute;
      bottom: calc(100% + 12px);
      left: 50%;
      transform: translateX(-50%);
      background: #1e1e1e;
      color: #f0f0f0;
      font-size: 0.72rem;
      line-height: 1.5;
      padding: 0.35rem 0.6rem;
      border-radius: 5px;
      width: max-content;
      max-width: min(220px, 80vw);
      white-space: normal;
      text-align: center;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 100;
    }
    .tutorial-body :global(.glossary-term:hover::before),
    .tutorial-body :global(.glossary-term:hover::after) {
      opacity: 1;
    }
  </style>

  <script>
    // 코드 블록 복사 버튼
    document.querySelectorAll('.tutorial-body pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = '복사';
      pre.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.innerText : pre.innerText;
        await navigator.clipboard.writeText(text);
        btn.textContent = '복사됨';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = '복사';
          btn.classList.remove('copied');
        }, 1500);
      });
    });

    // URL 자동 하이퍼링크
    const urlRegex = /https?:\/\/[^\s<>"'）)]+/g;

    // 1. 일반 텍스트 노드 안의 URL (p, li 직접 자식 텍스트)
    document.querySelectorAll('.tutorial-body p, .tutorial-body li').forEach((el) => {
      el.childNodes.forEach((node) => {
        if (node.nodeType !== Node.TEXT_NODE) return;
        const text = node.textContent;
        if (!urlRegex.test(text)) return;
        urlRegex.lastIndex = 0;
        const span = document.createElement('span');
        span.innerHTML = text.replace(urlRegex, (url) =>
          `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`
        );
        node.replaceWith(span);
      });
    });

    // 2. 인라인 코드(`url`) 안의 URL — pre 블록 제외
    document.querySelectorAll('.tutorial-body :not(pre) > code').forEach((code) => {
      const text = code.textContent ?? '';
      if (!urlRegex.test(text)) return;
      urlRegex.lastIndex = 0;
      const a = document.createElement('a');
      a.href = text.trim();
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.appendChild(code.cloneNode(true));
      code.replaceWith(a);
    });

    // 용어 툴팁
    const glossaryTerms = [
      { regex: /커밋/g, tip: '파일 변경 사항을 기록하는 것. 게임의 세이브포인트 같은 개념' },
      { regex: /푸시/g, tip: '내 컴퓨터의 커밋을 GitHub에 올리는 것' },
      { regex: /포크/g, tip: '남의 저장소를 내 계정으로 복사해 오는 것' },
      { regex: /클론/g, tip: '저장소를 내 컴퓨터에 내려받는 것' },
      { regex: /저장소/g, tip: '코드와 파일을 담아두는 공간. GitHub의 프로젝트 폴더' },
      { regex: /배포/g, tip: '만든 사이트를 인터넷에 올려 누구나 볼 수 있게 하는 것' },
      { regex: /빌드/g, tip: '소스 코드를 실제 사이트 파일로 변환하는 과정' },
      { regex: /터미널/g, tip: '명령어를 입력해 컴퓨터를 조작하는 검은 화면' },
      { regex: /오픈소스/g, tip: '코드를 누구나 볼 수 있게 공개한 프로젝트. 가져다 쓰거나 수정할 수 있음' },
      { regex: /레포(?!\s*지)/g, tip: '저장소의 줄임말 (repository → repo). GitHub의 프로젝트 공간' },
      { regex: /마크다운/g, tip: '#으로 제목, **로 굵게 등 기호로 서식을 표현하는 텍스트 형식' },
      { regex: /브랜치/g, tip: '코드의 독립적인 작업 흐름. main이 기본 브랜치' },
      { regex: /라이선스/g, tip: '오픈소스를 가져다 쓸 때 지켜야 하는 조건과 규칙' },
      { regex: /라이센스/g, tip: '오픈소스를 가져다 쓸 때 지켜야 하는 조건과 규칙' },
      { regex: /로컬/g, tip: '내 컴퓨터 안에서만 동작. 인터넷에는 아직 공개 안 된 상태' },
      { regex: /자연어/g, tip: '코드나 명령어가 아닌, 평소 쓰는 일상 언어' },
      { regex: /\bFork\b/g, tip: '남의 저장소를 내 계정으로 복사해 오는 것' },
      { regex: /\bClone\b/g, tip: '저장소를 내 컴퓨터에 내려받는 것' },
      { regex: /\bpush\b/g, tip: '내 컴퓨터의 커밋을 GitHub에 올리는 것' },
      { regex: /\bcommit\b/g, tip: '파일 변경 사항을 기록하는 것. 게임의 세이브포인트 같은 개념' },
      { regex: /\bMarkdown\b/g, tip: '#으로 제목, **로 굵게 등 기호로 서식을 표현하는 텍스트 형식' },
      { regex: /\bMIT\b/g, tip: '가장 자유로운 오픈소스 라이선스. 수정·재배포·상업 이용 모두 허용' },
      { regex: /\bPrivate\b/g, tip: '나만 볼 수 있는 저장소 설정' },
      { regex: /\bPublic\b/g, tip: '누구나 볼 수 있는 저장소 설정' },
      { regex: /\bGit\b/g, tip: '파일 변경 이력을 기록하고 관리하는 도구. 커밋·푸시·브랜치가 모두 Git 기능' },
      { regex: /깃/g, tip: '파일 변경 이력을 기록하고 관리하는 도구. 커밋·푸시·브랜치가 모두 Git 기능' },
      { regex: /\bVercel\b/g, tip: '코드를 자동으로 웹사이트로 만들어 올려주는 서비스. 무료로 사용 가능' },
      { regex: /\bGitHub\b/g, tip: '코드를 저장하고 공유하는 온라인 서비스. 오픈소스 저장소를 가져올 수도 있음' },
      { regex: /\bAntigravity\b/g, tip: 'AI가 내 컴퓨터 파일을 직접 읽고 수정할 수 있는 작업 환경 (Claude Code 앱)' },
      { regex: /Claude Code/g, tip: 'Antigravity 안에서 파일 작업을 도와주는 AI 어시스턴트' },
      { regex: /\bClaude\b/g, tip: 'Anthropic이 만든 AI. 자연어로 대화하면서 작업을 함께 진행' },
      { regex: /\bbkit\b/g, tip: 'Claude Code 작업 흐름을 체계적으로 잡아주는 설정 모음' },
    ];

    function applyGlossary(container) {
      const walker = document.createTreeWalker(
        container,
        NodeFilter.SHOW_TEXT,
        {
          acceptNode(node) {
            const skip = node.parentElement?.closest('pre, code, a, .glossary-term, h1, h2, h3');
            return skip ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT;
          }
        }
      );

      const textNodes = [];
      let n;
      while ((n = walker.nextNode())) textNodes.push(n);

      for (const textNode of textNodes) {
        const text = textNode.textContent ?? '';

        // 모든 용어의 매칭 위치 수집
        const matches = [];
        for (const { regex, tip } of glossaryTerms) {
          regex.lastIndex = 0;
          let m;
          while ((m = regex.exec(text)) !== null) {
            matches.push({ start: m.index, end: m.index + m[0].length, term: m[0], tip });
          }
        }
        if (matches.length === 0) continue;

        // 위치순 정렬 (같은 위치면 긴 매칭 우선 — 예: "Claude Code" > "Claude")
        matches.sort((a, b) => a.start !== b.start ? a.start - b.start : (b.end - b.start) - (a.end - a.start));
        const kept = [];
        let cursor = 0;
        for (const m of matches) {
          if (m.start >= cursor) { kept.push(m); cursor = m.end; }
        }

        // 텍스트 노드를 분해해서 span으로 교체
        const frag = document.createDocumentFragment();
        let pos = 0;
        for (const m of kept) {
          if (m.start > pos) frag.appendChild(document.createTextNode(text.slice(pos, m.start)));
          const span = document.createElement('span');
          span.className = 'glossary-term';
          span.dataset.tooltip = m.tip;
          span.textContent = m.term;
          frag.appendChild(span);
          pos = m.end;
        }
        if (pos < text.length) frag.appendChild(document.createTextNode(text.slice(pos)));
        textNode.replaceWith(frag);
      }
    }

    const tutorialBody = document.querySelector('.tutorial-body');
    if (tutorialBody) applyGlossary(tutorialBody);
  </script>
</Base>
