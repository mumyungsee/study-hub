---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TOC from '../components/TOC.astro';
import { getSectionKey } from '../config/nav';

export interface Props {
  title: string;
  description?: string;
  showTOC?: boolean;
}

const { title, description = 'AI 스터디 허브', showTOC = false } = Astro.props;

const pathname = Astro.url.pathname;
const section = getSectionKey(pathname);
const hasSidebar = section !== null;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header />

    <div class="app-body" id="app-body">
      {hasSidebar && <Sidebar />}

      <main class="main-content">
        <div class="content-inner">
          <slot />
        </div>
      </main>

      {showTOC && <TOC />}
    </div>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} 아루나 · 개인 기록과 발견</p>
    </footer>

    <style is:global>
      :root {
        --bg: #fafaf7;
        --fg: #222;
        --muted: #777;
        --accent: #6b4f3a;
        --line: #e5e2d9;
        --max-width: 720px;
        --header-height: 52px;
        --sidebar-width: 260px;
        --toc-width: 220px;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
        font-size: 17px;
        line-height: 1.75;
        word-break: keep-all;
      }

      .app-body {
        display: flex;
        min-height: calc(100vh - var(--header-height));
      }

      .main-content {
        flex: 1;
        min-width: 0;
        overflow-x: hidden;
      }

      .content-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 1.5rem;
        color: var(--muted);
        font-size: 0.88rem;
        text-align: center;
      }
      .site-footer p { margin: 0; }

      a { color: var(--accent); }
      h1, h2, h3 { line-height: 1.3; }
      h1 { font-size: 1.8rem; margin-top: 0; }
      h2 { font-size: 1.35rem; margin-top: 2.5rem; }
      h3 { font-size: 1.1rem; }
      p { margin: 1.1rem 0; }

      pre {
        background: #f0ede4;
        padding: 1rem;
        border-radius: 6px;
        overflow-x: auto;
      }
      code {
        background: #f0ede4;
        padding: 0.1rem 0.3rem;
        border-radius: 3px;
        font-size: 0.92em;
      }
      pre code { background: transparent; padding: 0; }

      blockquote {
        border-left: 3px solid var(--accent);
        margin-left: 0;
        padding-left: 1rem;
        color: var(--muted);
      }

      @media (max-width: 768px) {
        .content-inner { padding: 1.5rem 1rem 3rem; }
      }
    </style>
  </body>
</html>
