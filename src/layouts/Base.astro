---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TOC from '../components/TOC.astro';
import { hasSidebar as checkHasSidebar } from '../config/nav';

export interface Props {
  title: string;
  description?: string;
  showTOC?: boolean;
}

const { title, description = 'AI 스터디 허브', showTOC = false } = Astro.props;

const pathname = Astro.url.pathname;
const hasSidebar = checkHasSidebar(pathname);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header />

    <div class="app-body" id="app-body">
      {hasSidebar && <Sidebar />}

      <main class="main-content">
        <div class="content-inner">
          <slot />
        </div>
      </main>

      {showTOC && <TOC />}
    </div>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} 아루나 · 개인 기록과 발견</p>
    </footer>

    <style is:global>
      :root {
        --bg: #fafaf7;
        --fg: #222;
        --muted: #777;
        --accent: #6b4f3a;
        --line: #e5e2d9;
        --max-width: 720px;
        --header-height: 52px;
        --sidebar-width: 260px;
        --toc-width: 220px;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
        font-size: 17px;
        line-height: 1.75;
        word-break: keep-all;
      }

      .app-body {
        display: flex;
        min-height: calc(100vh - var(--header-height));
      }

      .main-content {
        flex: 1;
        min-width: 0;
        overflow-x: hidden;
      }

      .content-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 1.5rem;
        color: var(--muted);
        font-size: 0.88rem;
        text-align: center;
      }
      .site-footer p { margin: 0; }

      a { color: var(--accent); }
      h1, h2, h3 { line-height: 1.3; }
      h1 { font-size: 1.8rem; margin-top: 0; }
      h2 { font-size: 1.35rem; margin-top: 2.5rem; }
      h3 { font-size: 1.1rem; }
      p { margin: 1.1rem 0; }

      pre {
        background: #f0ede4;
        padding: 1rem;
        border-radius: 6px;
        overflow-x: auto;
      }
      code {
        background: #f0ede4;
        padding: 0.1rem 0.3rem;
        border-radius: 3px;
        font-size: 0.92em;
      }
      pre code { background: transparent; padding: 0; }

      blockquote {
        border-left: 3px solid var(--accent);
        margin-left: 0;
        padding-left: 1rem;
        color: var(--muted);
      }

      @media (max-width: 768px) {
        .content-inner { padding: 1.5rem 1rem 3rem; }
      }

      /* =================================================================
         공용 페이지 컴포넌트
         (.page-body 안에서 쓰는 클래스들 — 환경 세팅·메타학습 등)
         리뉴얼 시 이 블록만 수정하면 모든 페이지에 반영됨
         ================================================================= */

      /* h2 섹션 구분 */
      .page-body h2 {
        border-top: 1px solid var(--line);
        padding-top: 2rem;
        margin-top: 3rem;
      }
      .page-body h2:first-of-type {
        border-top: none;
        padding-top: 0;
        margin-top: 2rem;
      }
      .page-body h3 {
        margin-top: 1.8rem;
        color: var(--accent);
      }

      /* 전체 흐름 박스 */
      .flow {
        background: #faf7f1;
        border-left: 4px solid var(--accent);
        border-radius: 0 6px 6px 0;
        padding: 1rem 1.25rem 1rem 2.5rem;
        margin: 1rem 0;
      }
      .flow li { margin: 0.4rem 0; line-height: 1.5; }

      /* blockquote 변형 (intro / warning / info / success) */
      blockquote.intro,
      blockquote.warning,
      blockquote.info,
      blockquote.success {
        padding: 0.8rem 1.2rem;
        border-radius: 0 6px 6px 0;
        color: var(--fg);
      }
      blockquote.intro   { background: #f5f0e8; border-left-color: var(--accent); }
      blockquote.warning { background: #fef6e7; border-left-color: #d6a13a; }
      blockquote.info    { background: #f0f4f7; border-left-color: #6b8aa3; font-size: 0.94rem; }
      blockquote.success { background: #eaf3ea; border-left-color: #5a8a5a; }

      /* OS 분기 details (.os-alt) */
      .os-alt {
        background: #faf8f2;
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 0.6rem 1rem;
        margin: 1rem 0 1.5rem;
      }
      .os-alt > summary {
        cursor: pointer;
        font-weight: 600;
        color: var(--accent);
        font-size: 0.95rem;
      }
      .os-alt[open] > summary { margin-bottom: 0.6rem; }

      /* 복사용 프롬프트 박스 */
      .prompt-box {
        background: #f5f0e8;
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 1rem 1.2rem;
        margin: 1rem 0;
      }
      .prompt-box pre {
        margin: 0;
        background: rgba(255, 255, 255, 0.7);
      }
      .prompt-label {
        margin: 0 0 0.4rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--muted);
      }

      /* 프롬프트 비교 박스 (나쁜 예 / 좋은 예) */
      .prompt-compare {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem;
        margin: 1rem 0;
      }
      .prompt-bad, .prompt-good { padding: 0.8rem; border-radius: 6px; }
      .prompt-bad  { background: #fbeded; border-left: 3px solid #c97070; }
      .prompt-good { background: #eaf3ea; border-left: 3px solid #5a8a5a; }
      .prompt-bad pre, .prompt-good pre {
        margin: 0;
        background: rgba(255, 255, 255, 0.6);
        font-size: 0.88rem;
        padding: 0.6rem 0.8rem;
      }
      @media (max-width: 600px) { .prompt-compare { grid-template-columns: 1fr; } }

      /* 마무리 요약 박스 */
      .meta-summary {
        background: #f5f0e8;
        border-left: 4px solid var(--accent);
        border-radius: 0 6px 6px 0;
        padding: 1rem 1.4rem 1.1rem;
        margin: 1.2rem 0;
      }
      .meta-summary ol { margin: 0.3rem 0 0.8rem; padding-left: 1.4rem; }
      .meta-summary ol li { margin: 0.5rem 0; }

      /* 보조 텍스트 */
      .hint  { font-size: 0.92rem; color: var(--muted); margin-top: 0.4rem; }
      .muted { font-size: 0.88rem; color: var(--muted); }

      /* 코드 블록 복사 버튼 */
      .page-body pre { position: relative; }
      .page-body .copy-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.2rem 0.6rem;
        font-size: 0.72rem;
        background: rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 4px;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.15s;
        color: inherit;
        font-family: inherit;
      }
      .page-body pre:hover .copy-btn { opacity: 1; }
      .page-body .copy-btn.copied {
        background: rgba(0, 160, 80, 0.12);
        border-color: rgba(0, 160, 80, 0.3);
        color: #0a7a40;
        opacity: 1;
      }

      /* === 용어 툴팁 (공용 — 튜토리얼·환경 세팅 페이지 등) === */
      .glossary-term {
        border-bottom: 1px dashed var(--muted);
        cursor: help;
        position: relative;
      }
      .glossary-term::before {
        content: '';
        position: absolute;
        bottom: calc(100% + 2px);
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-top-color: #1e1e1e;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s;
        z-index: 101;
      }
      .glossary-term::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: calc(100% + 12px);
        left: 50%;
        transform: translateX(-50%);
        background: #1e1e1e;
        color: #f0f0f0;
        font-size: 0.72rem;
        line-height: 1.5;
        padding: 0.35rem 0.6rem;
        border-radius: 5px;
        width: max-content;
        max-width: min(220px, 80vw);
        white-space: normal;
        text-align: center;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s;
        z-index: 100;
      }
      .glossary-term:hover::before,
      .glossary-term:hover::after {
        opacity: 1;
      }
    </style>
  </body>
</html>
